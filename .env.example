# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/effortlessinsight

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (Required)
OPENAI_API_KEY=sk-...

# Google Cloud Document AI (Primary OCR)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# Azure Form Recognizer (Fallback OCR - Optional)
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your-key

# AWS (for S3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=effortlessinsight-uploads

# API Key (Optional - for service authentication)
API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5000"]

# Monitoring (Optional)
SENTRY_DSN=

# API Service URL (for callbacks)
API_SERVICE_URL=http://localhost:5000

# OCR Settings
OCR_CONFIDENCE_THRESHOLD=0.70

# LLM Settings
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# RAG Settings
RAG_TOP_K=10
RAG_MIN_SIMILARITY=0.5

# Pipeline Settings
PIPELINE_TIMEOUT_SECONDS=180
