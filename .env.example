# EffortlessInsight AI Service - Environment Variables Template
# Copy this file to .env and fill in the values for your environment
# NEVER commit .env files with real secrets to version control

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# DATABASE (PostgreSQL with pgvector)
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/effortlessinsight_ai

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# =============================================================================
# GOOGLE CLOUD (Document AI)
# =============================================================================
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us
GOOGLE_PROCESSOR_ID=your-processor-id

# =============================================================================
# AZURE (Form Recognizer - Fallback OCR)
# =============================================================================
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your-azure-key

# =============================================================================
# API SECURITY
# =============================================================================
API_KEY=your-internal-api-key

# =============================================================================
# ERROR TRACKING (Sentry)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# PERFORMANCE
# =============================================================================
MAX_WORKERS=4
PROCESSING_TIMEOUT_SECONDS=90
OCR_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# STORAGE (for temporary files)
# =============================================================================
TEMP_STORAGE_PATH=/tmp/effortlessinsight
MAX_FILE_SIZE_MB=25
